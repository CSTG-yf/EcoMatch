{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Bank chart recommendation and grounded explanation sample",
  "type": "object",
  "required": [
    "id", "source", "split", "templateGroup", "scene", "question",
    "dataProfile", "result", "chartAnnotation", "explanationAnnotation"
  ],
  "properties": {
    "id": {"type": "string"},
    "source": {"const": "competition_workbook"},
    "split": {"enum": ["train", "dev", "test"]},
    "templateGroup": {"type": "string"},
    "scene": {"enum": ["OPERATION_ANALYSIS", "RISK_CONTROL", "CUSTOMER_MARKETING"]},
    "question": {"type": "string", "minLength": 1},
    "dataProfile": {"type": "object"},
    "result": {"type": "object", "required": ["columns", "rowCount", "rows", "sha256"]},
    "chartAnnotation": {
      "type": "object",
      "required": ["recommended", "alternatives", "notRecommended", "rationale", "confidence"]
    },
    "explanationAnnotation": {
      "type": "object",
      "required": [
        "requiredClaims", "metricDefinitions", "timeRange", "scope",
        "requiredRiskNotices", "forbiddenClaims", "lowConfidencePolicy", "referenceExplanation"
      ]
    }
  },
  "additionalProperties": false
}
